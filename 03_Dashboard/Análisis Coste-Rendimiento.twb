      </column>
      <column caption='Once_Ideal' datatype='string' name='[Calculation_1928385108818472960]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Player] = &quot;Joan García&quot;&#13;&#10;OR [Player] = &quot;Marcos Senesi&quot;&#13;&#10;OR [Player] = &quot;Ibrahima Konaté&quot;&#13;&#10;OR [Player] = &quot;Maxence Lacroix&quot;&#13;&#10;OR [Player] = &quot;David Raum&quot;&#13;&#10;OR [Player] = &quot;Patrick Dorgu&quot;&#13;&#10;OR [Player] = &quot;Mateus Fernandes&quot;&#13;&#10;OR [Player] = &quot;Martín Zubimendi&quot;&#13;&#10;OR [Player] = &quot;Marcus Rashford&quot;&#13;&#10;OR [Player] = &quot;Said El Mala&quot;&#13;&#10;OR [Player] = &quot;Vangelis Pavlidis&quot;&#13;&#10;THEN &quot;Sí&quot;&#13;&#10;ELSE &quot;No&quot;&#13;&#10;END' />
      </column>
      <column caption='Pos_XI' datatype='string' name='[Calculation_1928385108821856257]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Player] = &quot;Joan García&quot; THEN &quot;GK&quot;&#13;&#10;&#13;&#10;ELSEIF [Player] = &quot;Marcos Senesi&quot; THEN &quot;DF&quot;&#13;&#10;ELSEIF [Player] = &quot;Ibrahima Konaté&quot; THEN &quot;DF&quot;&#13;&#10;ELSEIF [Player] = &quot;Maxence Lacroix&quot; THEN &quot;DF&quot;&#13;&#10;&#13;&#10;ELSEIF [Player] = &quot;David Raum&quot; THEN &quot;WB&quot;&#13;&#10;ELSEIF [Player] = &quot;Patrick Dorgu&quot; THEN &quot;WB&quot;&#13;&#10;&#13;&#10;ELSEIF [Player] = &quot;Mateus Fernandes&quot; THEN &quot;MC&quot;&#13;&#10;ELSEIF [Player] = &quot;Martín Zubimendi&quot; THEN &quot;MC&quot;&#13;&#10;&#13;&#10;ELSEIF [Player] = &quot;Marcus Rashford&quot; THEN &quot;MP&quot;&#13;&#10;ELSEIF [Player] = &quot;Said El Mala&quot; THEN &quot;MP&quot;&#13;&#10;&#13;&#10;ELSEIF [Player] = &quot;Vangelis Pavlidis&quot; THEN &quot;FW&quot;&#13;&#10;END' />
      </column>
      <column caption='Valor_XI_Unico' datatype='integer' name='[Calculation_1928385108824326146]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [Player] : MAX([Valor_M€]) }' />
      </column>
      <column caption='Coste_Fichaje' datatype='integer' name='[Calculation_1928385108848742403]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Finaliza_Contrato] = &quot;Sí&quot; THEN 0&#13;&#10;ELSE [Valor_M€]&#13;&#10;END' />
      </column>
      <column caption='Coste_Fichaje_Unico' datatype='integer' name='[Calculation_1928385108848918532]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [Player] : MAX([Calculation_1928385108848742403]) }' />
      </column>
